Bootstrap: docker
From: ubuntu:24.04

%post
  APT_INSTALL="apt install -y"
  apt update
  #============================================================
  # Base system and development environment
  #============================================================
  ${APT_INSTALL} emacs gedit gedit-plugins tcsh zsh fish rust-all libboost-dev cmake rclone libhwloc-dev numactl ghostscript \
                 imagemagick ncview evince sshfs xfce4 xfce4-terminal dbus-x11 x11-utils xdg-utils curl lmod mesa-utils
  cd /opt
  curl -L "https://download.mozilla.org/?product=firefox-latest-ssl&os=linux64-aarch64" -o firefox.tar
  tar xf firefox.tar
  rm -f firefox.tar
  #
  # Screen saver disabled for remote desktop usage
  apt remove -y xfce4-screensaver light-locker
  #
  # NVIDIA Nsight Compute
  ${APT_INSTALL} libxcb-dri2-0 libxcb-cursor0 libglapi-mesa
  #
  # TurboVNC
  ${APT_INSTALL} gpg wget libturbojpeg
  wget -q -O- https://packagecloud.io/dcommander/turbovnc/gpgkey | gpg --dearmor >/etc/apt/trusted.gpg.d/TurboVNC.gpg
  cd /etc/apt/sources.list.d/
  wget https://raw.githubusercontent.com/TurboVNC/repo/main/TurboVNC.list
  apt update
  ${APT_INSTALL} turbovnc python3-websockify
  #
  # VirtualGL
  wget -q -O- https://packagecloud.io/dcommander/virtualgl/gpgkey | gpg --dearmor >/etc/apt/trusted.gpg.d/VirtualGL.gpg
  cd /etc/apt/sources.list.d
  wget https://raw.githubusercontent.com/VirtualGL/repo/main/VirtualGL.list
  apt update
  ${APT_INSTALL} virtualgl

  #============================================================
  # Visualization software
  #============================================================
  # Gnuplot
  ${APT_INSTALL} gnuplot

  # ParaView
  ${APT_INSTALL} paraview

  # PyMOL
  ${APT_INSTALL} pymol python3-pymol python3-zombie-imp

  # OVITO
  cd /opt
  wget https://www.ovito.org/download/master/ovito-basic-3.15.5-aarch64.tar.xz
  tar Jxf ovito-basic-3.15.5-aarch64.tar.xz
  rm ovito-basic-3.15.5-aarch64.tar.xz
  ln -s ovito-basic-3.15.5-aarch64 ovito
  #============================================================
  # Interactive application (Optional)
  #============================================================
  # JupyterLab
  #${APT_INSTALL} python3 python3-venv python3-pip
  #python3 -m venv /opt/jupyterlab
  #/opt/jupyterlab/bin/pip install --upgrade pip
  #/opt/jupyterlab/bin/pip install jupyterlab

  #============================================================
  # Finalization and cleanup
  #============================================================
  apt clean all

%environment
  # VirtualGL
  export PATH=/opt/VirtualGL/bin:$PATH

  # firefox
  export PATH=/opt/firefox:$PATH

  # OVITO
  export PATH=/opt/ovito/bin:$PATH
  