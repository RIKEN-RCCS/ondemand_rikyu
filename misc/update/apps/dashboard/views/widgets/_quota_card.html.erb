<%
  block_pct = quota.block_percent
  inode_pct = quota.inode_percent

  bar_class = lambda do |pct|
    return 'bg-secondary' if pct.nil?
    if pct >= 90
      'bg-danger'
    elsif pct >= 70
      'bg-warning'
    else
      'bg-success'
    end
  end
%>
<div class="card mb-4 quota-card">
  <div class="card-header">
    <h3><i class="fas <%= icon %>" aria-hidden="true"></i> <%= title %></h3>
  </div>
  <div class="card-body">
    <div class="mb-3">
      <div class="d-flex justify-content-between">
        <span><%= t('dashboard.quota.space', default: 'Space') %></span>
        <span>
          <%- if block_pct.nil? -%>
            <%= number_to_human_size(quota.used_bytes) %> (<%= t('dashboard.quota.no_limit', default: 'no limit') %>)
          <%- else -%>
            <%= number_to_human_size(quota.used_bytes) %> / <%= number_to_human_size(quota.limit_bytes) %> (<%= block_pct %>%)
          <%- end -%>
        </span>
      </div>
      <div class="progress" role="progressbar" aria-label="<%= t('dashboard.quota.space', default: 'Space') %>" aria-valuenow="<%= block_pct || 0 %>" aria-valuemin="0" aria-valuemax="100">
        <div class="progress-bar <%= bar_class.call(block_pct) %>" style="width: <%= [block_pct || 0, 100].min %>%"></div>
      </div>
    </div>
    <div>
      <div class="d-flex justify-content-between">
        <span><%= t('dashboard.quota.files', default: 'Files') %></span>
        <span>
          <%- if inode_pct.nil? -%>
            <%= number_with_delimiter(quota.used_files) %> (<%= t('dashboard.quota.no_limit', default: 'no limit') %>)
          <%- else -%>
            <%= number_with_delimiter(quota.used_files) %> / <%= number_with_delimiter(quota.limit_files) %> (<%= inode_pct %>%)
          <%- end -%>
        </span>
      </div>
      <div class="progress" role="progressbar" aria-label="<%= t('dashboard.quota.files', default: 'Files') %>" aria-valuenow="<%= inode_pct || 0 %>" aria-valuemin="0" aria-valuemax="100">
        <div class="progress-bar <%= bar_class.call(inode_pct) %>" style="width: <%= [inode_pct || 0, 100].min %>%"></div>
      </div>
    </div>
  </div>
</div>
