<div class="card mb-4 links-card">
  <div class="card-header">
    <h3><i class="fas fa-link" aria-hidden="true"></i> <%= t('dashboard.links.title', default: 'Links') %></h3>
  </div>
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <span>
        <i class="fas fa-fw fa-globe" aria-hidden="true"></i> <%= t('dashboard.links.portal', default: 'RIKYU Portal') %>
      </span>
      <span>
	<a class="btn btn-sm btn-outline-secondary" href="https://portal.rikyu.r-ccs.riken.jp/en/" target="_blank" rel="noopener">EN</a>
	<a class="btn btn-sm btn-outline-secondary" href="https://portal.rikyu.r-ccs.riken.jp/ja/" target="_blank" rel="noopener">JA</a>
      </span>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-2">
      <span><i class="fas fa-fw fa-book" aria-hidden="true"></i> <%= t('dashboard.links.user_guide', default: 'RIKYU User Guide') %></span>
      <span>
        <a class="btn btn-sm btn-outline-secondary" href="https://docs.r-ccs.riken.jp/rikyu/en/" target="_blank" rel="noopener">EN</a>
        <a class="btn btn-sm btn-outline-secondary" href="https://docs.r-ccs.riken.jp/rikyu/ja/" target="_blank" rel="noopener">JA</a>
      </span>
    </div>
    <div class="d-flex justify-content-between align-items-center">
      <span><i class="fas fa-fw fa-envelope" aria-hidden="true"></i> <%= t('dashboard.links.contact', default: 'RIKYU Contact') %></span>
      <span>
        <a class="btn btn-sm btn-outline-secondary" href="https://docs.r-ccs.riken.jp/rikyu/en/contact/" target="_blank" rel="noopener">EN</a>
        <a class="btn btn-sm btn-outline-secondary" href="https://docs.r-ccs.riken.jp/rikyu/ja/contact/" target="_blank" rel="noopener">JA</a>
      </span>
    </div>
  </div>
</div>
